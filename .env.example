# Supabase proje ayarları (Proje Ayarları > API sekmesinden alınır)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# YALNIZCA SUNUCU TARAFI. Asla NEXT_PUBLIC_ önekiyle kullanılmaz, client
# bundle'a girmez. Yalnızca src/lib/supabase/admin.ts içinde, route handler
# içinde kullanılır (rapor üretimi, e-posta gönderimi gibi güvenilir sunucu
# işlemleri için).
SUPABASE_SERVICE_ROLE_KEY=

# SendGrid (https://sendgrid.com) — e-posta gönderimi yalnızca sunucu
# tarafında yapılır (Teslim 9). Wix DNS subdomain'de MX kaydını
# desteklemediğinden Resend yerine SendGrid'e geçildi — SendGrid'in
# "Automated Security" domain authentication'ı yalnızca CNAME kaydı
# gerektirir, MX gerektirmez (bkz. CLAUDE.md).
SENDGRID_API_KEY=
EMAIL_FROM="MESMER İSG360 <isg@mesmer-mym.com>"

# Uygulamanın kendi mutlak URL'i — e-posta içindeki "Raporu Görüntüle"
# bağlantıları ve signed URL üretimi için kullanılır.
NEXT_PUBLIC_APP_URL=http://localhost:3000
